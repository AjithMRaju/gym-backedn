# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/gym_website
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/gym_website

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
